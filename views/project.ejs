<%- include("layout-top") %>

<section class="pt-10">
  <a href="/projects" class="inline-flex items-center gap-2 rounded-xl bg-black/5 px-3 py-2 text-sm ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
    <span>←</span>
    <span><%= t("project.back") %></span>
  </a>

  <div class="mt-6 rounded-3xl border border-black/10 bg-white/70 p-7 shadow-soft dark:border-white/10 dark:bg-white/5 <%= lang==='ar' ? 'text-right' : '' %>">
    <div class="flex items-start justify-between gap-3 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
      <div>
        <h1 class="text-2xl font-semibold text-slate-900 dark:text-white"><%= (project.name[lang] || project.name.en) %></h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300"><%= (project.summary[lang] || project.summary.en) %></p>
      </div>
      <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs text-emerald-700 ring-1 ring-emerald-400/20 dark:text-emerald-200"><%= lang==='ar' ? 'مشروع' : 'Project' %></span>
    </div>

    <div class="mt-4 flex flex-wrap gap-2 <%= lang==='ar' ? 'justify-end' : '' %>">
      <% project.stack.forEach((s) => { %>
        <span class="rounded-full bg-cyan-500/10 px-3 py-1 text-xs text-cyan-700 ring-1 ring-cyan-400/20 dark:text-cyan-200"><%= s %></span>
      <% }) %>
    </div>

    <h2 class="mt-8 text-sm font-semibold text-slate-900 dark:text-white"><%= lang==='ar' ? 'ماذا تم تنفيذه' : 'What I delivered' %></h2>
    <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-700 dark:text-slate-200 <%= lang==='ar' ? 'pr-5 pl-0 text-right list-inside' : '' %>">
      <% (project.details[lang] || project.details.en).forEach((d) => { %>
        <li><%= d %></li>
      <% }) %>
    </ul>

    <div class="mt-8 grid gap-3 sm:grid-cols-2">
      <a href="/#contact" class="rounded-2xl bg-cyan-500 px-5 py-3 text-center text-sm font-semibold text-white hover:bg-cyan-600">
        <%= lang==='ar' ? 'تواصل معي' : 'Contact me' %>
      </a>
      <a href="/download/cv" class="rounded-2xl bg-black/5 px-5 py-3 text-center text-sm font-semibold ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15">
        <%= t("cta.download_cv") %>
      </a>
    </div>
  </div>
</section>

<%- include("layout-bottom") %>
