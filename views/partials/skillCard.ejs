<div class="reveal rounded-3xl border border-black/10 bg-black/5 p-6 shadow-soft dark:border-white/10 dark:bg-white/5">
  <div class="flex items-center justify-between <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
    <div class="text-sm font-semibold text-slate-900 dark:text-white"><%= title %></div>
    <span class="rounded-full bg-white/40 px-3 py-1 text-xs text-slate-700 ring-1 ring-black/10 dark:bg-white/5 dark:text-slate-300 dark:ring-white/10"><%= items.length %></span>
  </div>
  <div class="mt-4 flex flex-wrap gap-2 <%= lang==='ar' ? 'justify-end' : '' %>">
    <% items.forEach((item) => { %>
      <span class="rounded-full bg-white/60 px-3 py-1 text-xs text-slate-800 ring-1 ring-black/10 dark:bg-slate-950/40 dark:text-slate-200 dark:ring-white/10"><%= item %></span>
    <% }) %>
  </div>
</div>
