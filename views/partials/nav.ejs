<header class="sticky top-0 z-50 border-b border-black/10 bg-white/70 backdrop-blur dark:border-white/10 dark:bg-slate-950/70">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <a href="/#top" class="group inline-flex items-center gap-2">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-black/5 ring-1 ring-black/10 shadow-soft dark:bg-white/10 dark:ring-white/10">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="text-cyan-600 dark:text-cyan-300">
            <path d="M12 2l8.5 4.5v11L12 22l-8.5-4.5v-11L12 2Z" stroke="currentColor" stroke-width="1.8"/>
            <path d="M7.5 8.5h9v7h-9v-7Z" stroke="currentColor" stroke-width="1.8"/>
          </svg>
        </span>
        <div class="leading-tight">
          <div class="text-sm font-semibold tracking-tight"><%= profile.name %></div>
          <div class="text-xs text-slate-600 dark:text-slate-300"><%= profile.title %></div>
        </div>
      </a>

      <nav class="hidden md:flex items-center gap-6 text-sm text-slate-700 dark:text-slate-200 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
        <a class="hover:text-black dark:hover:text-white" href="/#about"><%= t("nav.about") %></a>
        <a class="hover:text-black dark:hover:text-white" href="/#skills"><%= t("nav.skills") %></a>
        <a class="hover:text-black dark:hover:text-white" href="/#experience"><%= t("nav.experience") %></a>
        <a class="hover:text-black dark:hover:text-white" href="/projects"><%= t("nav.projects") %></a>
        <a class="hover:text-black dark:hover:text-white" href="/blog"><%= t("nav.blog") %></a>
        <a class="hover:text-black dark:hover:text-white" href="/#education"><%= t("nav.education") %></a>
        <a class="hover:text-black dark:hover:text-white" href="/#contact"><%= t("nav.contact") %></a>
      </nav>

      <div class="flex items-center gap-2 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
        <a href="/download/cv" class="hidden sm:inline-flex items-center rounded-xl bg-black/5 px-3 py-2 text-sm font-medium ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15">
          <%= t("cta.download_cv") %>
        </a>

        <a href="/#contact" class="inline-flex items-center rounded-xl bg-cyan-500/15 px-3 py-2 text-sm font-medium text-cyan-700 ring-1 ring-cyan-400/30 hover:bg-cyan-500/20 dark:text-cyan-200">
          <%= t("cta.hire") %>
        </a>

        <!-- Language toggle -->
        <button id="langToggle"
          class="inline-flex h-10 items-center justify-center rounded-xl bg-black/5 px-3 text-sm font-medium ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15"
          aria-label="Toggle language" title="Toggle language">
          <span class="font-semibold"><%= lang === 'ar' ? 'EN' : 'AR' %></span>
        </button>

        <!-- Theme toggle -->
        <button id="themeToggle"
          class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-black/5 ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15"
          aria-label="Toggle theme" title="Toggle theme">
          <svg id="sunIcon" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none">
            <path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z" stroke="currentColor" stroke-width="2"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
              stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg id="moonIcon" class="h-5 w-5" viewBox="0 0 24 24" fill="none">
            <path d="M21 14.5A8.5 8.5 0 0 1 9.5 3a7 7 0 1 0 11.5 11.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          </svg>
        </button>

        <button id="menuBtn" class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-xl bg-black/5 ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15" aria-label="Open menu">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobileMenu" class="md:hidden hidden pb-4">
      <div class="grid gap-2 rounded-2xl border border-black/10 bg-black/5 p-3 dark:border-white/10 dark:bg-white/5 <%= lang==='ar' ? 'text-right' : '' %>">
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/#about"><%= t("nav.about") %></a>
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/#skills"><%= t("nav.skills") %></a>
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/#experience"><%= t("nav.experience") %></a>
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/projects"><%= t("nav.projects") %></a>
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/blog"><%= t("nav.blog") %></a>
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/#education"><%= t("nav.education") %></a>
        <a class="rounded-xl px-3 py-2 hover:bg-black/10 dark:hover:bg-white/10" href="/#contact"><%= t("nav.contact") %></a>

        <div class="mt-2 flex gap-2 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
          <a href="/download/cv" class="flex-1 rounded-xl bg-black/5 px-3 py-2 text-center text-sm font-medium ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15">
            <%= t("cta.download_cv") %>
          </a>
          <a href="/#contact" class="flex-1 rounded-xl bg-cyan-500/15 px-3 py-2 text-center text-sm font-medium text-cyan-700 ring-1 ring-cyan-400/30 hover:bg-cyan-500/20 dark:text-cyan-200">
            <%= t("cta.hire") %>
          </a>
        </div>

        <div class="mt-2 flex gap-2 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
          <a class="flex-1 rounded-xl bg-black/5 px-3 py-2 text-center text-sm ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15" href="<%= profile.socials.github %>" target="_blank" rel="noreferrer">GitHub</a>
          <a class="flex-1 rounded-xl bg-black/5 px-3 py-2 text-center text-sm ring-1 ring-black/10 hover:bg-black/10 dark:bg-white/10 dark:ring-white/10 dark:hover:bg-white/15" href="<%= profile.socials.linkedin %>" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </div>
</header>
