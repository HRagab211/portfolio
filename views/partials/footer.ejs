<footer class="mt-16 border-t border-black/10 dark:border-white/10">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 text-sm text-slate-600 dark:text-slate-400">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between <%= lang==='ar' ? 'sm:flex-row-reverse' : '' %>">
      <div>© <%= new Date().getFullYear() %> <span class="font-semibold text-slate-900 dark:text-slate-200"><%= profile.name %></span>.</div>
      <div class="flex items-center gap-4 <%= lang==='ar' ? 'flex-row-reverse' : '' %>">
        <a class="hover:text-slate-900 dark:hover:text-slate-200" href="mailto:<%= profile.email %>"><%= profile.email %></a>
        <a class="hover:text-slate-900 dark:hover:text-slate-200" href="<%= profile.socials.github %>" target="_blank" rel="noreferrer">GitHub</a>
        <a class="hover:text-slate-900 dark:hover:text-slate-200" href="<%= profile.socials.linkedin %>" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
